# =============================================================================
# Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=
LOG_LEVEL=INFO

# =============================================================================
# OpenAI-compatible API (ProxyAPI/OpenAI)
# =============================================================================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.proxyapi.ru/openai/v1
# Запасной ключ для совместимости
# OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
# Для vision (описание собаки по фото); по умолчанию совпадает с OPENAI_CHAT_MODEL
# OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# =============================================================================
# Weaviate Cloud (Haystack WeaviateDocumentStore)
# =============================================================================
WEAVIATE_URL=https://xxxxxx.weaviate.network
WEAVIATE_API_KEY=
# Имя коллекции; для Haystack нужна схема с полями haystack (см. README). Старые `Vpg05Memory` / `Vpg06HaystackMemory` не смешивать.
WEAVIATE_COLLECTION_NAME=Vpg07HaystackMemory
# Для vpg_telegram.v2 задайте отдельное имя (расширенная схема под чанки файлов), например:
# WEAVIATE_COLLECTION_NAME=Vpg07HayV2

# Групповой бот (vpg_telegram.group): отдельная коллекция; не смешивать с v1/v2
# WEAVIATE_GROUP_COLLECTION_NAME=Vpg07GroupChat
# GROUP_RAG_TOP_K=16
# GROUP_SESSION_MAX_CHARS=200000
# GROUP_MENTION_MAX_TOKENS=2000
# GROUP_SESSION_SUMMARY_MAX_TOKENS=2500

# Сколько фрагментов памяти подставлять в системный промпт
MEMORY_TOP_K=8
# Сколько чанков загруженных документов подставлять в промпт (vpg_telegram.v2)
FILE_RAG_TOP_K=8
# Чанкование после Docling (Haystack DocumentSplitter)
DOC_CHUNK_WORDS=200
DOC_CHUNK_OVERLAP=40
# Макс. символов текста для одно-предложенного резюме после загрузки файла
DOC_SUMMARY_MAX_CHARS=12000
# Макс. сообщений в краткой истории чата (роли user/assistant/tool)
CHAT_HISTORY_MAX_MESSAGES=24
# Лимит шагов агента (вызовы LLM / инструменты)
MAX_AGENT_STEPS=12
